# Database Configuration for Docker PostgreSQL container
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_DB=lms_database
POSTGRES_PORT=5432

# Prisma Database Connection String
# Inside Docker Network, host is 'db'
DATABASE_URL="postgresql://admin:password123@db:5432/lms_database?schema=public"

# For local development (outside Docker)
# DATABASE_URL="postgresql://admin:password123@localhost:5432/lms_database?schema=public"

# Server Configuration
PORT=5000
